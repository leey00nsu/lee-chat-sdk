{
  "name": "lee-chat-sdk",
  "version": "0.3.1",
  "description": "Drop-in chat widget kit for React and vanilla JavaScript websites.",
  "license": "MIT",
  "author": "leeyoonsu",
  "keywords": [
    "chat",
    "chat-widget",
    "customer-support",
    "sdk",
    "react",
    "vanilla-js"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vanilla": {
      "types": "./dist/vanilla.d.ts",
      "import": "./dist/vanilla.js",
      "require": "./dist/vanilla.cjs"
    },
    "./global": {
      "types": "./dist/global.d.ts",
      "import": "./dist/global.js",
      "require": "./dist/global.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./style.css": {
      "default": "./dist/index.css"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md",
    "README.md",
    "README.en.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/vanilla.ts src/global.ts src/testing.ts src/server.ts --format esm,cjs --dts --clean && tsup --entry.lee-chat src/global.ts --format iife --globalName LeeChat --out-dir dist --minify --inject-style --clean=false && node ../../scripts/create-cdn-manifest.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm --workspace-root release:check",
    "release:check": "pnpm --workspace-root release:ready && pnpm typecheck && pnpm test:run && pnpm build && pnpm pack:dry-run",
    "test": "vitest",
    "test:run": "vitest run --pool=forks --maxWorkers=1",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15"
  }
}
